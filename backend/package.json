{
  "name": "uwb-peer-compass-backend",
  "version": "1.0.0",
  "description": "Rendezvous broker for uwb-peer-compass. Auth, contacts, presence, session negotiation and opaque token exchange. Never stores measurements.",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "openapi:gen": "tsx src/scripts/gen-openapi.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^8.14.0",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.18.0",
    "argon2": "^0.40.3",
    "fastify": "^4.28.1",
    "jose": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/ws": "^8.5.11",
    "ajv": "^8.17.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "prettier": "^3.3.3",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "ws": "^8.18.0"
  }
}
