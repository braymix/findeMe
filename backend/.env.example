# Copy to .env for local development.
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://uwb:uwb@localhost:5432/uwb_peer_compass?schema=public

# JWT signing secret (min 32 bytes). Generate: openssl rand -base64 48
JWT_SECRET=dev-only-insecure-secret-change-me-please-32bytes+
ACCESS_TOKEN_TTL=900          # seconds (15 min)
REFRESH_TOKEN_TTL=604800      # seconds (7 days)

# Session timeouts (ms)
INVITE_TIMEOUT_MS=30000
SETUP_TIMEOUT_MS=20000
ACTIVE_MAX_MS=900000

# Rate limiting
RATE_LIMIT_AUTH_PER_MIN=10
